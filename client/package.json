{
	"name": "client",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"app": "electron electron/main.cjs",
		"monitor": "electron electron/main.cjs",
		"build": "tsc -b && vite build",
		"dist": "npm run build && electron-builder --win dir && node electron/copy-runtime.cjs",
		"lint": "eslint .",
		"preview": "vite preview"
	},
	"dependencies": {
		"@tanstack/react-query": "^5.100.9",
		"lucide-react": "^1.14.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-markdown": "^10.1.0",
		"react-router-dom": "^7.14.1",
		"remark-gfm": "^4.0.1"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/node": "^24.12.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"electron": "^42.0.1",
		"electron-builder": "^26.8.1",
		"eslint": "^9.39.4",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"globals": "^17.4.0",
		"typescript": "~6.0.2",
		"typescript-eslint": "^8.58.0",
		"vite": "^8.0.4"
	},
	"main": "electron/main.cjs",
	"build": {
		"appId": "local.vivi.agent",
		"productName": "Vivi",
		"executableName": "Vivi",
		"directories": {
			"output": "../dist-app"
		},
		"files": [
			"electron/**/*",
			"package.json"
		],
		"extraResources": [
			{
				"from": "../src",
				"to": "app/src"
			},
			{
				"from": "../prompts",
				"to": "app/prompts"
			},
			{
				"from": "../data",
				"to": "app/data",
				"filter": [
					"**/*",
					"!screenshots/**",
					"!monitor-edge-profile/**"
				]
			},
			{
				"from": "dist",
				"to": "app/client/dist"
			},
			{
				"from": "../requirements.txt",
				"to": "app/requirements.txt"
			}
		],
		"win": {
			"signAndEditExecutable": false,
			"target": [
				"dir"
			]
		}
	}
}
